GROQ_API_KEY=
PORT=8000

# Groq model ids
VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
REASONING_MODEL=llama-3.3-70b-versatile

# Hugging Face (used for the virtual staging / room restyle image generation feature)
# Free account + free token, no billing required: https://huggingface.co/settings/tokens/new?ownUserPermissions=inference.serverless.write&tokenType=fineGrained
HUGGINGFACE_API_KEY=
IMAGE_MODEL=black-forest-labs/FLUX.1-Kontext-dev
